<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <RootNamespace></RootNamespace>
    <IsPackable>False</IsPackable>
    <NoWarn>CS0649;CS0169</NoWarn>
    <FalloutTelemetryVersion>1</FalloutTelemetryVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Fallout.Common" Version="10.3.49" />
    <PackageDownload Include="GitVersion.Tool" Version="[5.12.0]" />
    <PackageDownload Include="docfx" Version="[2.78.5]" />
    <PackageReference Include="Fallout.Tooling.Generator" Version="10.3.49" />
    <!-- The references below are required to compiled the embedded files from
         the separate Fallout.GitHub and Fallout.WebDocu projects itself -->
    <PackageReference Include="Octokit" Version="14.0.0" />
    <PackageReference Include="Azure.Storage.Blobs" Version="12.29.1" />
  </ItemGroup>

  <ItemGroup>
    <FalloutMetadata Include="**/*.json" Exclude="bin/**;obj/**" />
  </ItemGroup>

  <ItemGroup>
    <!-- By linking the files here, we're not having any trouble with locked dlls
         during the build process -->
    <Compile Include="..\src\Fallout.GitHub\**\*.cs">
      <Link>FalloutGitHub\%(RecursiveDir)%(Filename)%(Extension)</Link>
    </Compile>
    <Compile Remove="..\src\Fallout.GitHub\obj\**" />
    <Compile Remove="..\src\Fallout.GitHub\bin\**" />
  </ItemGroup>

  <ItemGroup>
    <!-- By linking the files here, we're not having any trouble with locked dlls
         during the build process -->
    <Compile Include="..\src\Fallout.WebDocu\**\*.cs">
      <Link>FalloutWebDocu\%(RecursiveDir)%(Filename)%(Extension)</Link>
    </Compile>
    <Compile Remove="..\src\Fallout.WebDocu\obj\**" />
    <Compile Remove="..\src\Fallout.WebDocu\bin\**" />
  </ItemGroup>

</Project>
